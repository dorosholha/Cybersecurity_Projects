[{"content_html":"\u003ctitle\u003e\u003c/title\u003e\n\u003cstyle type=\"text/css\"\u003ebody {\n        margin: 0;\n        padding: 32px;\n        background-color: #f8f8f8;\n        font-family: Arial, sans-serif;\n    }\n\n    .container {\n        max-width: 600px;\n        width: 100%;\n        margin: auto;\n        border: 1px solid #c8c8c8;\n        border-radius: 8px;\n        background: #fff;\n        box-shadow: 0 3px 0 rgba(0,0,0,0.05);\n        text-align: center; \n    }\n\n    .header {\n        padding: 20px;\n        border-bottom: 1px solid #dedede;\n        text-align: center; \n    }\n\n    .header img {\n        width: 40px;\n        max-width: 100%;\n        height: auto;\n        display: block; \n        margin: 0 auto; \n    }\n\n    .header h1 {\n        font-size: 20px;\n        font-weight: bold;\n        color: #323130;\n        margin: 20px 0 0;\n    }\n\n    .content {\n        padding: 20px;\n        font-size: 16px;\n        color: #323130;\n    }\n\n    .doc-box {\n        display: block; \n        border: 1px solid #d2d2d2;\n        margin: 20px auto;\n        padding: 10px;\n        width: 90%;\n        background: #fff;\n        text-align: center; \n    }\n\n    .doc-box img {\n        display: inline-block; \n        width: 32px;\n        max-width: 100%;\n        height: auto;\n        margin-right: 10px;\n        vertical-align: middle;\n    }\n\n    .doc-box span {\n        display: inline-block; \n        font-size: 16px;\n        color: #323130;\n        vertical-align: middle;\n    }\n\n    .buttons {\n        margin: 20px 0 40px;\n        text-align: center; \n    }\n\n    .btn {\n        display: inline-block;\n        padding: 10px 20px;\n        margin: 5px;\n        border-radius: 4px;\n        font-size: 16px;\n        text-decoration: none;\n        width: 160px; \n        max-width: 100%;\n        box-sizing: border-box;\n    }\n\n    .btn-primary {\n        background: #005A9E;\n        color: #fff;\n    }\n\n    .btn-outline {\n        border: 1px solid #106ebe;\n        color: #106ebe;\n        background: #fff;\n    }\n\n    .footer {\n        font-size: 12px;\n        color: #323130;\n        padding: 10px 20px;\n        background: #f8f8f8;\n        text-align: center;\n    }\n\n   \n    @media (max-width: 480px) { \n        body {\n            padding: 16px;\n        }\n\n        .container {\n            padding-top: 5px;\n        }\n\n        .header h1 {\n            font-size: 18px;\n        }\n\n        .content {\n            padding: 20px 10px; \n        }\n\n        \n        .btn {\n            width: 45%;\n            max-width: 160px;\n            margin: 5px 2%; \n            display: inline-block; \n        }\n\n        .buttons {\n            margin-top: 30px; \n            margin-bottom: 30px;\n        }\n\n        .footer {\n            padding-top: 20px; \n            padding-bottom: 20px;\n        }\n    }\n\n    \n    @media (prefers-color-scheme: dark) {\n        body { background-color: #1e1e1e; }\n        .container { background: #2c2c2c; border-color: #444; }\n        .header h1, .content, .doc-box span, .footer { color: #e6e6e6; }\n        .doc-box { background: #333; border-color: #555; }\n        .btn-primary { background: #3388ff; }\n        .btn-outline { border-color: #66aaff; color: #66aaff; background: transparent; }\n    }\n\u003c/style\u003e\n\u003cdiv class=\"container\" style=\"max-width:600px; width:100%\"\u003e\n\u003cdiv class=\"header\"\u003e\n\u003cimg alt=\"SharePoint Logo\" src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/e/ec/Microsoft_Office_SharePoint_%282019%E2%80%932025%29.svg/960px-Microsoft_Office_SharePoint_%282019%E2%80%932025%29.svg.png?20190925170659\" style=\"display:block; height:39px; margin:0 auto; width:40px\" width=\"40\" height=\"39\"\u003e\u003cx-sei title=\"Logos can be faked! Seeing a company logo in an email does NOT guarantee it’s from them\"\u003e\u003c/x-sei\u003e\n\u003ch1\u003eGiuseppe Zambonelli shared a file with you\u003cx-sei title=\"Make sure the name matches the real email address. Don't click on links or open files from unknown senders\"\u003e\u003c/x-sei\u003e\n\u003c/h1\u003e\n\u003c/div\u003e\n\n\u003cdiv class=\"content\"\u003e\n\u003cp\u003eHere's the document that Giuseppe Zambonelli shared with you.\u003c/p\u003e\n\n\u003cdiv class=\"doc-box\"\u003e\n\u003cimg alt=\"Excel icon\" src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/f/f3/.xlsx_icon.svg/2048px-.xlsx_icon.svg.png\" style=\"height:30px; width:30px\" width=\"30\" height=\"30\"\u003e \u003cspan\u003eMaster Data Oniverse 2026 \u003cx-sei title=\"Were you expecting this file? Don't open unexpected files\"\u003e\u003c/x-sei\u003e\u003c/span\u003e\n\u003c/div\u003e\n\n\u003cdiv class=\"buttons\"\u003e\n\u003ca class=\"btn btn-primary\" href=\"[[URL]]\" style=\"background: #005A9E; color: #fff; width: 160px; display: inline-block; padding: 10px 20px; border-radius: 4px; text-decoration: none; box-sizing: border-box;\"\u003eOpen\u003c/a\u003e \u003ca class=\"btn btn-outline\" href=\"[[URL]]\" style=\"border: 1px solid #106ebe; color: #106ebe; background: #fff; width: 160px; display: inline-block; padding: 10px 20px; border-radius: 4px; text-decoration: none; box-sizing: border-box;\"\u003eShare\u003c/a\u003e\u003cx-sei title=\"Hover over the link to see the real URL. Make sure it matches the site you expect to visit\"\u003e\u003c/x-sei\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n\n\u003cdiv class=\"footer\"\u003e\n\u003cp\u003eMicrosoft Corporation, One Microsoft Way, ​Redmond, WA 98052​\u003c/p\u003e\n\u003c/div\u003e\n\u003c/div\u003e\n","content_text":null,"from":"\u003cx-sei title='The domain \"sharepoint-micrsoft.eu\" is not an official Microsoft domain'\u003enoreply@sharepoint-micrsoft.eu\u003c/x-sei\u003e","subject":"\u003cx-sei title=\"If you don’t know the sender or weren’t expecting a file, don't open it!\"\u003eGiuseppe Zambonelli shared \"Master Data Oniverse 2026\" with you\u003c/x-sei\u003e","attachment_type":null,"attachment_filename":null,"sophistication":"significant","reply_to":"","from_display_name":"\u003cx-sei title=\"The sender’s name can be faked! Always verify the sender’s email address\"\u003eSharePoint\u003c/x-sei\u003e","name":"Sharepoint: User shared a file with you [ENG]","reply_to_display_name":"","template_translation_uuid":"736d3f77-3dee-47e3-954f-f7a2b9133989","language_code":"it-it"}]