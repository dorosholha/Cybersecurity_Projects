<title></title>
<style type="text/css">:root {
            color-scheme: light dark;
            supported-color-schemes: light dark;
        }
        body {
            margin: 0;
            padding: 0;
            width: 100% !important;
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }
        img {
            border: 0;
            line-height: 100%;
            outline: none;
            text-decoration: none;
        }
        table {
            border-collapse: collapse !important;
        }
        
        /* Stili per Dark Mode */
        @media (prefers-color-scheme: dark) {
            .wrapper { background-color: #1a1a1a !important; }
            .content-td { background-color: #242424 !important; }
            .text-main { color: #e0e0e0 !important; }
            .text-gray { color: #aaaaaa !important; }
            .footer-td { border-top-color: #444444 !important; }
        }
</style>
<table align="center" border="0" cellpadding="0" cellspacing="0" class="wrapper" role="presentation" style="background-color:#f9f9f9; width:100%">
	<tbody>
		<tr>
			<td align="center" style="padding:20px 0">
			<table border="0" cellpadding="0" cellspacing="0" class="content-td" style="background-color:#ffffff; max-width:600px; width:100%">
				<tbody>
					<tr>
						<td style="padding:48px 40px 0 40px"><img alt="OpenAI" src="https://upload.wikimedia.org/wikipedia/commons/4/4d/OpenAI_Logo.svg" style="border:none; display:block; width:120px" width="120"></td>
					</tr>
					<tr>
						<td style="padding:40px 40px 20px 40px">
						<p class="text-main" style="color:#4d4d4d; font-size:16px; line-height:1.6; margin-bottom:20px; margin-left:0; margin-right:0; margin-top:0">Hi&nbsp;<strong>[[first_name]]</strong>,<br />
						<br />
						You’ve been invited to collaborate in the Oniverse workspace on ChatGPT Business Team.</p>

						<p class="text-main" style="color:#4d4d4d; font-size:16px; line-height:1.6; margin-bottom:0; margin-left:0; margin-right:0; margin-top:0">Click the button below to accept the invitation.</p>
						</td>
					</tr>
					<tr>
						<td style="padding:20px 40px 30px 40px">
						<div><a href="[[URL]]" style="background-color:#0ba37f; background-image: linear-gradient(#0ba37f, #0ba37f); border:1px solid #0ba37f; border-radius:4px; color:#ffffff; display:inline-block; font-family:Arial, sans-serif; font-size:15px; font-weight:bold; line-height:45px; text-align:center; text-decoration:none; width:200px; -webkit-text-size-adjust:none; ">Join the Team</a></div>
						</td>
					</tr>
					<tr>
						<td style="padding:0 40px 40px 40px">
						<p class="text-gray" style="color:#888888; font-size:13px; font-style:italic; margin-bottom:0; margin-left:0; margin-right:0; margin-top:0">This link will expire in 24 hours.</p>
						</td>
					</tr>
					<tr>
						<td class="footer-td" style="border-top:1px solid #eeeeee; padding:20px 40px">
						<p class="text-gray" style="color:#999999; font-size:12px; line-height:1.5; margin-bottom:0; margin-left:0; margin-right:0; margin-top:0">If you experience any issues, please visit our&nbsp;<a href="[[URL]]" style="color: #0ba37f; text-decoration: none;">Help Center</a>.</p>

						<p style="color:#b0b0b0; font-size:11px; line-height:1.4; margin-top:25px">OpenAI, LLC<br />
						3180 18th St, San Francisco, CA 94110</p>
						</td>
					</tr>
				</tbody>
			</table>
			</td>
		</tr>
	</tbody>
</table>
