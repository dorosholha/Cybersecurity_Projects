            main { align-items: flex-start; height: auto; min-height: 100vh; padding-top: 24px; }
            .auth-wrapper { box-shadow: none !important; padding: 24px !important; width: unset !important; max-width: unset !important; margin: 0 30px !important; }
            .opts { box-shadow: none !important; padding: 8px 24px !important; border: 1px solid #999; max-width: calc(100% - 60px); margin: 28px 30px !important; }
